import pandas as pd

sold_list = []

for year in range(2024, 2027):
    for month in range(1, 13):
        if year == 2026 and month > 4:
            break

        if year == 2024 and month < 3:
            continue

        file = f"CRMLSSold{year}{month:02d}.csv"
        try:
            df = pd.read_csv(file)
            sold_list.append(df)
            print(f"Loaded {file}")
        except FileNotFoundError:
            print(f"Missing {file}")

sold = pd.concat(sold_list, ignore_index=True)
print("Final sold shape:", sold.shape)
